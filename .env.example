# Database (PostgreSQL)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=nas_db

# Core Service (FastAPI)
# Must match the postgres credentials above
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/nas_db
# Connection to Redis for tasks/caching
REDIS_URL=redis://redis:6379/0
# Connection to MinIO Object Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Security: Change this to a long random string for production!
SECRET_KEY=change_this_to_a_secure_random_key_in_production
ALGORITHM=HS256

# Transfer Engine (Go/QUIC)
# The public URL where the transfer engine is accessible
TRANSFER_ENGINE_URL=http://localhost:8081

# Frontend (Next.js)
# URL to the Core API
NEXT_PUBLIC_API_URL=http://localhost:8000
